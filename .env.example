# --- APIs externas ---------------------------------------------------------
# the-odds-api
ODDS_API_KEY=

# api-football
API_FOOTBALL_KEY=

# --- Telegram --------------------------------------------------------------
# TOKEN devuelto por @BotFather al crear el bot.
TELEGRAM_BOT_TOKEN=

# ID numérico del chat donde el bot manda notificaciones.
TELEGRAM_CHAT_ID=

# --- Google Sheets ---------------------------------------------------------
# Ruta al archivo JSON con las credenciales de la cuenta de servicio de Google.
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./credentials/sheets-sa.json

# ID del Google Sheet
GOOGLE_SHEET_ID=

# --- DB --------------------------------------------------------------------
DATABASE_URL=sqlite:///data/betting_bot.db

# --- Dead-man's switch (healthchecks.io) -----------------------------------
HEALTHCHECKS_URL=

# --- Operación -------------------------------------------------------------
LOG_LEVEL=INFO
TIMEZONE=America/Bogota
CURRENCY=COP
